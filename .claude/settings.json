{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git tag*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(tree*)",
      "Bash(wc*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(go version)",
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(go run*)",
      "Bash(go mod*)",
      "Bash(go vet*)",
      "Bash(golangci-lint*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm run test*)",
      "Bash(npm run typecheck*)",
      "Bash(npx tsc*)",
      "Bash(terraform init*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(terraform fmt*)",
      "Bash(terraform state list*)",
      "Bash(terraform state show*)",
      "Bash(terraform output*)",
      "Bash(az account show*)",
      "Bash(az group list*)",
      "Bash(az resource list*)",
      "Bash(az deployment group what-if*)",
      "Bash(az bicep build*)",
      "Bash(az bicep lint*)",
      "Bash(docker build*)",
      "Bash(docker images*)",
      "Bash(docker ps*)",
      "Bash(docker compose build*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(kubectl top*)",
      "Bash(kubectl config current-context)",
      "Bash(kubectl config get-contexts)",
      "Bash(helm list*)",
      "Bash(helm status*)",
      "Bash(helm template*)",
      "Bash(gh pr*)",
      "Bash(gh issue*)",
      "Bash(gh run*)",
      "Bash(gh workflow*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(terraform destroy*)",
      "Bash(terraform apply -auto-approve*)",
      "Bash(docker system prune*)",
      "Bash(az group delete*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/andre/.claude/plugins/marketplaces/caveman/hooks/caveman-statusline.sh\""
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "warp@claude-code-warp": true,
    "swift-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.92",
  "tui": "fullscreen",
  "voiceEnabled": true
}
