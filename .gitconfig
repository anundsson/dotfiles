[includeif "gitdir:~/repos/anundio/"]
	path = ~/src/anundio/.gitconfig_anundio
	
[includeif "gitdir:~/repos/home/"]
	path = ~/src/home/.gitconfig_home

[includeif "gitdir:~/dotfiles"]
	path = ~/src/home/.gitconfig_home
[init]
  defaultBranch = main

[user]
    name = André Anundsson
    email = andre@anundsson.net

[push]
    default = current
    autosetupremote = true

[maintenance]
	auto = false
	strategy = incremental

[rerere]
	enabled = true

[column]
  ui = auto

[branch]
  sort = -committerdate

[alias]
	staash = stash --all

[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
